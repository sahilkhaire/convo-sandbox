PORT=8080
DATABASE_URL=postgres://simulator:simulator@localhost:5433/messaging_sim?sslmode=disable
CORS_ORIGIN=http://localhost:3000
ENABLE_DATA_RESET=true
MEDIA_STORAGE_PATH=./data/media
DEFAULT_WEBHOOK_URL=http://localhost:9000/webhooks

# Auth (required in production — min 32 characters)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY_HOURS=24

# Frontend build (same-domain nginx: use relative /api)
# VITE_API_URL=/api
